# =====================================================
#  豆包 API（对话）— ARK 大模型
# =====================================================
ARK_API_KEY=your-ark-api-key-here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_MODEL=doubao-seed-character-251128

# 服务端口（默认 3000）
PORT=3000

# =====================================================
#  豆包语音（语音合成 TTS）
#  需开通「语音合成大模型 2.0（seed-tts-2.0）」
# =====================================================
# App ID（控制台 → 应用管理 → 服务接口认证信息 → APP ID）
DOUBAO_APP_ID=your-doubao-app-id

# Access Token（控制台 → 服务接口认证信息 → Access Token；与 ARK_API_KEY 不同）
VOLC_SPEECH_API_KEY=your-volc-speech-access-token

# Resource ID（非 saturn_ 音色用，语音合成大模型 2.0 = seed-tts-2.0，声音复刻 2.0 = seed-icl-2.0）
# 须与 voice_type 同属控制台已开通的「资源」；否则报 55000000 resource mismatched
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0

# saturn_ 前缀音色（如知性灿灿）Resource ID 须用 seed-tts-2.0
# 若仍报错 55000000 可尝试 seed-tts-2.0-expressive
DOUBAO_TTS_RESOURCE_ID_SATURN=seed-tts-2.0

# saturn_ 音色在 V3 请求体中须带 model（expressive 表现力强 / standard 更稳）
DOUBAO_TTS_SATURN_MODEL=seed-tts-2.0-expressive

# 业务集群（通常 volcano_tts）
DOUBAO_TTS_CLUSTER=volcano_tts

# 发音人 voice_type（示例：控制台「语音合成模型 2.0」知性灿灿）
DOUBAO_VOICE_TYPE=saturn_zh_female_cancan_tob

# 英文发音人 voice_type（示例：Tim）
DOUBAO_VOICE_TYPE_EN=en_male_tim_uranus_bigtts

# 语速和语调（0.5 ~ 2.0，推荐 0.9 ~ 1.0）
DOUBAO_TTS_SPEED=1.0
DOUBAO_TTS_PITCH=1.0
